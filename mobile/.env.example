# Target backend: local oppure public
# - local: usa EXPO_PUBLIC_API_BASE_URL_LOCAL
# - public: usa EXPO_PUBLIC_API_BASE_URL_PUBLIC
EXPO_PUBLIC_API_TARGET=local

# URL backend locale (simulatore o rete locale)
EXPO_PUBLIC_API_BASE_URL_LOCAL=http://localhost:8080

# URL backend pubblico (Beanstalk / endpoint AWS)
EXPO_PUBLIC_API_BASE_URL_PUBLIC=https://your-backend.example.com

# Override opzionale: se impostato, ha priorita' assoluta
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8080

# Overlay debug visibile in app (default: true in dev, false in release)
# EXPO_PUBLIC_SHOW_DEBUG_OVERLAY=true

