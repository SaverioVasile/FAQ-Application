# Copy this file to .env.aws.frontend and fill real values.
# Used by scripts/deploy-frontend-s3.sh

# Public URL of backend API (Elastic Beanstalk)
VITE_API_BASE_URL=http://faq-backend-prod.eu-west-1.elasticbeanstalk.com

# S3 bucket that hosts the static frontend
S3_BUCKET=your-frontend-bucket-name

# Optional CloudFront distribution id for cache invalidation
# Example: E123ABC456DEF
CLOUDFRONT_DISTRIBUTION_ID=

