# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Provider: local | rds
APP_DB_PROVIDER=local

# Local PostgreSQL (used when APP_DB_PROVIDER=local, via docker-compose)
APP_DB_LOCAL_URL=jdbc:postgresql://postgres:5432/faqdb
APP_DB_LOCAL_USERNAME=faq
APP_DB_LOCAL_PASSWORD=faq

# AWS RDS PostgreSQL (used when APP_DB_PROVIDER=rds)
# Get endpoint from AWS RDS Console
APP_DB_RDS_URL=jdbc:postgresql://<your-rds-endpoint>.eu-west-1.rds.amazonaws.com:5432/postgres
APP_DB_RDS_USERNAME=postgres
APP_DB_RDS_PASSWORD=<your-strong-password>

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
# Provider: smtp | ses
APP_MAIL_ENABLED=false
APP_MAIL_PROVIDER=smtp
APP_MAIL_FROM=no-reply@example.com

# SMTP settings (used when APP_MAIL_PROVIDER=smtp)
# Examples:
#  - Gmail: smtp.gmail.com / use App Password
#  - Outlook: smtp.office365.com
#  - Brevo: smtp-relay.brevo.com
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=<your-app-password>

# SES API settings (used when APP_MAIL_PROVIDER=ses)
# Generate credentials in AWS IAM Console (dedicated user recommended)
APP_MAIL_SES_REGION=eu-west-1
APP_MAIL_SES_ACCESS_KEY=<AWS_ACCESS_KEY_ID>
APP_MAIL_SES_SECRET_KEY=<AWS_SECRET_ACCESS_KEY>

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

